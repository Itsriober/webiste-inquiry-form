# .env.example
# Copy this file to .env and fill in all values before running locally.
# Never commit .env to version control.

# EmailJS — https://www.emailjs.com/
# Get these from your EmailJS dashboard after creating a service and template.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Dashboard Authentication
# Used on the client-side for form testing
VITE_DASHBOARD_PIN=your_secret_pin

# Server-side Dashboard PIN (for API authentication)
# Must be kept secret - never share this value
# Set this in Vercel Environment Variables
DASHBOARD_PIN_SECRET=your_secret_pin

# Google Sheets API — https://console.cloud.google.com/
# 1. Create a project in Google Cloud Console
# 2. Enable the Google Sheets API
# 3. Create an API key and restrict it to:
#    - Google Sheets API only
#    - HTTP referrers: your Vercel domain (e.g. https://your-app.vercel.app/*)
# 4. Create the target Google Sheet and add the header row (see AGENTS.md)
# 5. The spreadsheet ID is in the sheet URL:
#    https://docs.google.com/spreadsheets/d/SPREADSHEET_ID_HERE/edit
VITE_SHEETS_API_KEY=
VITE_SHEETS_SPREADSHEET_ID=
VITE_SHEETS_RANGE=Sheet1!A1
